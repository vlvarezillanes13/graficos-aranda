# --- Vercel / producción (server-only, sin prefijo VITE_) ---

AUTH_SESSION_SECRET=genera_un_secreto_largo_aleatorio

# AUTH_ADMIN_PASSWORD=clave_personalizada_opcional

# Vercel KV (Storage → KV en el dashboard). Obligatorio en producción para:
# - token ITSM compartido entre funciones
# - lista de casos urgentes compartida
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Local opcional (fallback si no usas las variables de arriba) ---

# VITE_AUTH_SESSION_SECRET="tu_secreto_con_comillas_si_tiene_#"

# Token ITSM: se ingresa por pantalla tras login (compartido en el servidor).
# Ya no uses ITSM_INTEGRATION_TOKEN ni create/token en .env.

# Sin KV en local, token ITSM y urgentes usan memoria del proceso (solo desarrollo).
