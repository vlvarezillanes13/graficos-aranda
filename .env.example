# Secreto para firmar sesiones de login (local y Vercel)
AUTH_SESSION_SECRET=genera_un_secreto_largo_aleatorio

# Token de autenticación ITSM
# Local (npm run dev): usa VITE_ITSM_AUTH_TOKEN en .env
# Vercel (producción): configura en Environment Variables del proyecto
#   ITSM_AUTH_TOKEN = Bearer tu_token
#   ITSM_AUTH_COOKIE = AuthCookieASMS=valor   (sin expires/path/HttpOnly)
# Marca Production y Preview. Luego haz Redeploy.
VITE_ITSM_AUTH_TOKEN=Bearer tu_token_aqui

# Cookie de sesión (opcional)
# Local: VITE_ITSM_AUTH_COOKIE
# Vercel: ITSM_AUTH_COOKIE
# VITE_ITSM_AUTH_COOKIE=AuthCookieASMS=...

# NO descomentar en desarrollo local: provoca error CORS en el navegador.
# En local usa npm run dev; Vite proxyea /api/itsm-search → https://itsm.sonda.com
# VITE_ITSM_BASE_URL=https://itsm.sonda.com
