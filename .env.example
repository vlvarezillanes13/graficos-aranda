# Token de autenticación ITSM (obligatorio para datos reales)
# Copia este archivo a .env y completa tus credenciales.
VITE_ITSM_AUTH_TOKEN=Bearer tu_token_aqui

# Cookie de sesión (opcional, algunos entornos la requieren)
# VITE_ITSM_AUTH_COOKIE=AuthCookieASMS=...

# Usar true para forzar datos de ejemplo sin llamar al API
# VITE_ITSM_USE_MOCK=true

# URL base alternativa (opcional). Si no se define, usa proxy local /api/itsm
# VITE_ITSM_BASE_URL=https://itsm.sonda.com
